{
  "name": "ava-pay-shopify",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "react-router build",
    "dev": "shopify app dev",
    "config:link": "shopify app config link",
    "deploy": "shopify app deploy",
    "generate": "shopify app generate",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "setup": "prisma generate && prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@react-router/node": "^7.18.1",
    "@react-router/serve": "^7.18.1",
    "@shopify/app-bridge-react": "^4.1.3",
    "@shopify/polaris": "^13.4.0",
    "@shopify/shopify-app-react-router": "^1.2.1",
    "@shopify/shopify-app-session-storage-prisma": "^9.0.1",
    "isbot": "^5.1.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.18.1"
  },
  "devDependencies": {
    "@react-router/dev": "^7.18.1",
    "@react-router/fs-routes": "^7.18.1",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "prisma": "^6.19.0",
    "typescript": "^5.5.3",
    "vite": "^6.4.3",
    "vite-tsconfig-paths": "^4.3.2",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "@babel/core": "^7.29.6",
    "morgan": "^1.11.0",
    "qs": "^6.15.2"
  }
}
