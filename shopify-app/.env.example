# Shopify Partners app credentials
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_orders,write_discounts,write_checkouts,read_customers
HOST=

# Where the AVA Pay /verify endpoint is reachable from this app.
# In dev, point this at the API server you scaffolded earlier.
AVA_PAY_API_URL=http://localhost:3000

# Local Prisma (SQLite). Switch to Postgres in production.
DATABASE_URL=file:./dev.sqlite

PORT=3001
